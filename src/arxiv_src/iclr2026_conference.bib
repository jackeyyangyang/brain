	keywords = {Computer Science - Computation and Language, Computer Science - Artificial Intelligence, Computer Science - Information Retrieval},
	file = {Preprint PDF:/Users/lakshyaaagrawal/Zotero/storage/ZIPWE97B/Song et al. - 2025 - R1-Searcher Incentivizing the Search Capability in LLMs via Reinforcement Learning.pdf:application/pdf;Snapshot:/Users/lakshyaaagrawal/Zotero/storage/J8YA869B/2503.html:text/html},
